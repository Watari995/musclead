# 本番VM用 .env テンプレート。これを deploy/.env にコピーして値を埋める。
# (deploy/.env は .gitignore 済み。秘密情報はコミットしない)
#
# 注意: DB_HOST / DB_PORT / ADDR は docker-compose 側で固定するのでここでは不要。

# --- MySQL (VM 内コンテナ) ---
MYSQL_ROOT_PASSWORD=   # 任意の強いパスワード
DB_NAME=musclead
DB_USER=musclead
DB_PASSWORD=           # 任意の強いパスワード

# --- CORS ---
ALLOWED_ORIGIN=https://app.musclead.com

# --- Object storage: Cloudflare R2 (S3 互換) ---
STORAGE_BUCKET=musclead-images
AWS_REGION=auto
STORAGE_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
STORAGE_PUBLIC_BASE_URL=https://<R2公開ドメイン または pub-xxxx.r2.dev>
AWS_ACCESS_KEY_ID=         # R2 API トークンのアクセスキー
AWS_SECRET_ACCESS_KEY=     # R2 API トークンのシークレット

# --- Email: Resend ---
RESEND_API_KEY=
MAIL_FROM_ADDRESS=no-reply@musclead.com

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SIGNING_SECRET=
STRIPE_SUCCESS_URL=https://app.musclead.com/purchase/success
STRIPE_CANCEL_URL=https://app.musclead.com/purchase/cancel
STRIPE_PORTAL_RETURN_URL=https://app.musclead.com/account

# --- App ---
JWT_SECRET=             # 任意の長いランダム文字列

# --- Redis (任意・未設定でOK。無くても起動する) ---
# REDIS_HOST=
# REDIS_PORT=6379

# --- Sentry (任意・未設定でエラー監視なし) ---
SENTRY_DSN=
