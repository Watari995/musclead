# MySQL (local docker-compose)
DB_USER=musclead
DB_PASSWORD=musclead
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=musclead

# goose
GOOSE_DRIVER=mysql
GOOSE_DBSTRING=musclead:musclead@tcp(127.0.0.1:3306)/musclead?parseTime=true&multiStatements=true
GOOSE_MIGRATION_DIR=./sql/migrations

# --- Object storage (S3互換: AWS S3 もしくは Cloudflare R2) ---
STORAGE_BUCKET=musclead-images
AWS_REGION=ap-northeast-1            # R2 を使う場合は auto
# R2 を使う場合のみ設定 (未設定なら AWS S3 として動作):
# STORAGE_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# STORAGE_PUBLIC_BASE_URL=https://<R2公開ドメイン もしくは pub-xxxx.r2.dev>
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY に R2 のアクセスキーを設定

# --- Email (Resend) ---
# 設定すると SQS/Lambda/SES を使わず Resend で直接送信する:
# RESEND_API_KEY=re_xxx
# MAIL_FROM_ADDRESS=no-reply@musclead.com

# --- Stripe ---
# STRIPE_SECRET_KEY=sk_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_WEBHOOK_SIGNING_SECRET=whsec_...
# STRIPE_SUCCESS_URL=
# STRIPE_CANCEL_URL=
# STRIPE_PORTAL_RETURN_URL=

# --- Redis (任意。未設定でも起動可) ---
# REDIS_HOST=
# REDIS_PORT=6379

# --- HealthPlanet API (healthsync モジュール) ---
# https://www.healthplanet.jp/apis_account.do で取得
# HEALTH_PLANET_CLIENT_ID=
# HEALTH_PLANET_CLIENT_SECRET=

# --- Frontend URL (OAuth callback リダイレクト先) ---
# FRONTEND_URL=https://app.musclead.com
