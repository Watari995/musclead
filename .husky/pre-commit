#!/usr/bin/env bash
# pre-commit: semgrep を走らせて違反があれば commit を止める。
# 詳細ルールは .semgrep.yml、 除外は .semgrepignore。

if ! command -v semgrep >/dev/null 2>&1; then
  echo "warning: semgrep が未インストール — pre-commit チェックをスキップ"
  echo "         brew install semgrep で導入してください"
  exit 0
fi

semgrep --config .semgrep.yml --error --quiet
